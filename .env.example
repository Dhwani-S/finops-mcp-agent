# Copy this file to .env and fill in your values

# --- LLM ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- GCP / BigQuery ---
GCP_PROJECT_ID=your_project_id
GCP_LOCATION=us-central1

# --- SQL Server (optional, for finops_sql_server) ---
SQL_SERVER_HOST=
SQL_SERVER_USER=
SQL_SERVER_PASS=
SQL_SERVER_DB=
