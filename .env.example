# Copy this file to .env and fill in your values

# --- LLM ---
# Model: gemini-2.5-pro (default), gemini-2.5-flash, gemini-2.0-flash, etc.
GEMINI_MODEL=gemini-2.5-pro

# For Vertex AI (recommended):
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Base64-encoded service account JSON (alternative to ADC)
# GCP_DEV_CREDENTIALS_BASE64=

# For API key mode (alternative to Vertex AI):
# GEMINI_API_KEY=your_gemini_api_key_here

# --- GCP / BigQuery ---
GCP_PROJECT_ID=cie-costmanagement-803717
GCP_LOCATION=us-central1
# Set this OR use `gcloud auth application-default login`
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# --- SQL Server (optional, for finops_sql_server) ---
SQL_SERVER_HOST=
SQL_SERVER_USER=
SQL_SERVER_PASS=
SQL_SERVER_DB=
